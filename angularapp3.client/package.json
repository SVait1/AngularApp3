{
  "name": "angularapp3.client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "run-script-os",
    "build": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",

    "start:windows": "ng serve --proxy-config proxy.conf.json --host=127.0.0.1 --port=4200",

    "start:default": "ng serve --proxy-config proxy.conf.json --host=127.0.0.1 --port=4200"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "21.1.5",
    "@angular/common": "21.1.5",
    "@angular/compiler": "21.1.5",
    "@angular/core": "21.1.5",
    "@angular/forms": "21.1.5",
    "@angular/platform-browser": "21.1.5",
    "@angular/router": "21.1.5",
    "jest-editor-support": "*",
    "run-script-os": "*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.1.5",
    "@angular/cli": "21.1.5",
    "@angular/compiler-cli": "21.1.5",
    "eslint": "^10.0.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
